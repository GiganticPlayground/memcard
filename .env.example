# Memcard service environment variables

# Server configuration
PORT=3000
NODE_ENV=development
# LOG_LEVEL=debug
# LOG_TYPE=pretty

# CORS configuration
# Leave unset to allow all origins.
# Use * to explicitly allow all origins.
# Example: http://localhost:3000,https://app.example.com
# CORS_ORIGINS=*

# Reverse proxy configuration
# Controls Express trust proxy behavior.
# Use false for direct connections, true to trust forwarded headers,
# or a number like 1 when exactly one proxy sits in front of the app.
# This matters for req.ip and IP-based rate limiting.
# TRUST_PROXY=false

# Per-client rate limiting on the PUT endpoint
# Disabled by default. Set to true to enable.
# RATE_LIMIT_ENABLED=false
# RATE_LIMIT_MAX=30
# RATE_LIMIT_WINDOW_MS=60000

# --- AWS / S3 ---
AWS_REGION=us-east-1
MEMCARD_S3_BUCKET=memcard-state
# {env} segment of the S3 key (fixed per deployment)
MEMCARD_ENV=dev
# MEMCARD_KEY_PREFIX=memcard
# Max PUT body size in bytes (default 2 MiB)
# MEMCARD_MAX_BODY_BYTES=2097152
# Sentinel ETag returned for non-existent state and used on first write
# MEMCARD_SENTINEL_ETAG=0
# MEMCARD_SCHEMA_VERSION=1
# Per-request timeout for S3 calls (ms)
# MEMCARD_S3_TIMEOUT_MS=5000
# Optional explicit S3 endpoint (e.g. LocalStack)
# MEMCARD_S3_ENDPOINT=http://localhost:4566
# MEMCARD_S3_FORCE_PATH_STYLE=false

# --- JWT verification ---
# How inbound JWTs are verified:
#   jwt-jwks  (default) — RS256, validated against the remote JWKS at JWKS_URI
#   jwt-hs256           — HS256, validated against the shared JWT_SECRET
# JWT_AUTH_MODE=jwt-jwks
#
# Required when JWT_AUTH_MODE=jwt-jwks. JWKS endpoint of the auth service that
# issues tokens (e.g. Token Weaver).
JWKS_URI=https://auth.example.com/.well-known/jwks.json
# Required when JWT_AUTH_MODE=jwt-hs256. Shared secret the issuer signs with.
# JWT_SECRET=change-me
JWT_ISSUER=https://auth.example.com
# JWT_AUDIENCE=memcard
# Claim that carries the {app} segment of the S3 key
# JWT_APP_CLAIM=app

# Graceful shutdown
# SHUTDOWN_TIMEOUT_MS=30000

# API documentation
# API_DOCS_ENABLED=true

{
  "name": "memcard-service",
  "version": "1.0.0",
  "type": "module",
  "main": "index.js",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/GiganticPlayground/memcard-service.git"
  },
  "scripts": {
    "dev": "nodemon --exec tsx src/index.ts",
    "start": "node --import=tsx src/index.ts",
    "build": "rm -rf dist && tsc --noEmit false --outDir dist && node scripts/fix-dist-esm-imports.js dist",
    "setup": "bash scripts/setup.sh",
    "dev:keys": "node scripts/generate-jwt-keys.js",
    "generate": "npm run gen-types && npm run gen-controllers",
    "gen-types": "npx openapi-typescript ./api/openapi.yaml -o ./src/types/schema.d.ts",
    "gen-controllers": "node scripts/generate-controllers.js",
    "test": "node --import=tsx --test tests/**/*.test.ts",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"api/**/*.yaml\" \"scripts/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"api/**/*.yaml\" \"scripts/**/*.js\"",
    "type-check": "tsc --noEmit",
    "validate": "npm run type-check && npm run lint && npm run format:check"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1058.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-openapi-validator": "^5.6.0",
    "express-rate-limit": "^8.5.0",
    "helmet": "^8.1.0",
    "jose": "^6.2.3",
    "js-yaml": "^4.1.0",
    "logra": "github:GiganticPlayground/logra#semver:^1.0.0",
    "swagger-ui-express": "^5.0.1",
    "token-weaver": "github:GiganticPlayground/token-weaver#semver:^1.0.0",
    "yaml": "^2.8.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@smithy/util-stream": "^4.6.6",
    "@types/cors": "^2.8.19",
    "@types/helmet": "^4.0.0",
    "@types/node": "^24.9.2",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "aws-sdk-client-mock": "^4.1.0",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^17.23.1",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
